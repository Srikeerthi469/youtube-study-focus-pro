{
  "manifest_version": 3,
  "name": "YouTube Study Focus Pro",
  "version": "2.0",
  "description": "Blocks YouTube feeds, shorts, and includes a built-in Pomodoro study timer.",
  "permissions": ["storage", "alarms", "notifications"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
